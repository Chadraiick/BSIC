# ─────────────────────────────────────────────────────────────────
# BSIC AI Backend — Variables d'environnement
# Copiez ce fichier en ".env" pour le développement local
# Sur Render : ajoutez ces variables dans "Environment" > "Add Variable"
# ─────────────────────────────────────────────────────────────────

# Port d'écoute (Render le définit automatiquement — ne pas modifier)
PORT=3000

# URL autorisée pour le frontend (CORS)
FRONTEND_URL=https://votre-frontend.onrender.com

# Clé secrète pour signer les JWT — changez en production
JWT_SECRET=changez-moi-en-production-avec-une-cle-longue

# ── Twilio WhatsApp ──────────────────────────────────────────────
# Trouvez ces valeurs sur : https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Numéro Twilio WhatsApp (sandbox = whatsapp:+14155238886)
# En production, mettez votre numéro approuvé Meta
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Mode (development = désactive la validation de signature Twilio pour tests locaux)
NODE_ENV=development
