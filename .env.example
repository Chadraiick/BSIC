# ─────────────────────────────────────────────────────────────────
# BSIC AI Backend — Variables d'environnement
# Copiez ce fichier en ".env" pour le dev local
# Sur Render : ajoutez dans "Environment" > "Add Variable"
# ─────────────────────────────────────────────────────────────────

# Port (Render le définit automatiquement)
PORT=3000

# CORS — URL exacte de votre frontend
FRONTEND_URL=https://votre-frontend.onrender.com

# JWT secret — changez en production
JWT_SECRET=changez-moi-en-production-avec-une-cle-longue

# ── Claude API (fallback intelligent) ───────────────────────────
# Obtenez votre clé sur : https://console.anthropic.com
# Si absent : le bot utilise uniquement le NLP local
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio WhatsApp ──────────────────────────────────────────────
# Console : https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Sandbox Twilio = whatsapp:+14155238886
# Production = votre numéro approuvé Meta
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Mode dev = désactive la validation de signature Twilio
NODE_ENV=development
