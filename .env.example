# ─────────────────────────────────────────────────────────────────
# BSIC AI Backend — Variables d'environnement
# Sur Render : "Environment" > "Add Variable"
# ─────────────────────────────────────────────────────────────────

# Port (Render le définit automatiquement — ne pas toucher)
PORT=3000

# CORS — URL exacte de votre frontend déployé
FRONTEND_URL=https://votre-frontend.onrender.com

# JWT secret — changez obligatoirement en production
JWT_SECRET=changez-moi-en-production-avec-une-cle-longue

# ── Claude API (fallback intelligent pour messages longs) ────────
# Obtenez votre clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio ───────────────────────────────────────────────────────
# Console : https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Sandbox Twilio = whatsapp:+14155238886
# Numéro de production approuvé = whatsapp:+VOTRE_NUMERO
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Mode d'envoi WhatsApp :
#   false (défaut) = TwiML inline → recommandé pour le SANDBOX Twilio
#   true           = API Twilio   → recommandé pour un numéro de production approuvé
TWILIO_USE_API=false

# Validation de la signature Twilio (sécurité) :
#   false (défaut) = désactivée → plus simple, fonctionne toujours
#   true           = activée    → activer seulement si vous avez un numéro de prod approuvé
TWILIO_VALIDATE_SIGNATURE=false
